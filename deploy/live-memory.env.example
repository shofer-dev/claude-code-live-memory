# Live Memory server configuration — systemd EnvironmentFile.
# Copy to live-memory.env and edit. Every value is OPTIONAL; omit to use the
# built-in default. (install-service.sh copies this for you if none exists.)

# ── Server bind ──
#LIVE_MEMORY_HOST=127.0.0.1
#LIVE_MEMORY_PORT=7711

# ── Persistence (this is what makes memory survive restarts) ──
# Per-workspace snapshots live here as <hash>.json. Default (unset) is
# ~/.claude/plugins/data/live-memory under the service user's HOME — already
# stable across restarts. Pin an absolute path if you want it elsewhere.
#LIVE_MEMORY_DATA_DIR=/var/lib/live-memory

# ── Model / provider ──
# ZERO-CONFIG: leave provider + key UNSET and stay logged into a Claude
# subscription — the service reuses ~/.claude/.credentials.json and runs on
# Haiku (see install-service.sh: this requires the service to run as YOU).
#
# …or choose a provider explicitly:
#LIVE_MEMORY_PROVIDER=openai
#LIVE_MEMORY_BASE_URL=https://api.deepseek.com
#LIVE_MEMORY_MODEL=deepseek-chat
#LIVE_MEMORY_API_KEY=sk-...
# (anthropic with an API key instead of subscription:)
#LIVE_MEMORY_PROVIDER=anthropic
#LIVE_MEMORY_API_KEY=sk-ant-...

# ── Same-workspace concurrency ──
# Default "parallel": fork the window per question, longest-explored fork wins,
# no queue delay. Set "serial" for one-at-a-time (shared window grows in place).
#LIVE_MEMORY_CONCURRENCY=parallel          # or: serial
#LIVE_MEMORY_MAX_PARALLEL_QUERIES=4

# ── KV / prompt-cache keep-warm (OFF by default — opt in) ──
# Periodically ping each recently-active workspace's prefix so the provider cache
# doesn't go cold (cold = the next query re-reads the whole prefix at full rate).
# The interval comes from provider knowledge: Anthropic/OpenAI ~240s (their caches
# are minutes); DeepSeek is auto-set very long (its disk cache lasts hours/days),
# so even when enabled keep-warm effectively self-disables there.
#LIVE_MEMORY_KEEP_WARM=true                 # default false; set true to enable
#LIVE_MEMORY_KEEP_WARM_INTERVAL_S=240       # seconds between pings (provider default if unset)
#LIVE_MEMORY_KEEP_WARM_MAX_IDLE_S=1800      # stop warming a workspace idle longer than this

# ── Async (fire-and-forget) tools — opt-in, off by default ──
# When true, ALSO expose ask_live_memory_submit (returns a job_id immediately)
# and ask_live_memory_result (poll for the answer). MCP has no native async tool
# calls; this is a server-side submit/poll pattern the agent must drive.
#LIVE_MEMORY_ASYNC_TOOLS=false

# ── Workspace keying ──
#LIVE_MEMORY_CANONICALIZE_WORKSPACE=true
#LIVE_MEMORY_REPO_ROOT_MODE=nearest        # or: outermost

# ── Limits ──
#LIVE_MEMORY_MAX_CONTEXT_TOKENS=128000     # artificial budget (cost cap); compaction holds the window here
#LIVE_MEMORY_DEFAULT_TIMEOUT_S=90
#LIVE_MEMORY_MAX_QUEUE_SIZE=100

# ── Pricing (for the $ shown in /stats) ──
# Built-in defaults cover haiku/sonnet/opus/gpt-4o*/deepseek/gemini by name.
# To set EXACT rates for the model this server runs (wins over the table):
#LIVE_MEMORY_PRICE_INPUT=0.10              # USD per 1M input tokens
#LIVE_MEMORY_PRICE_OUTPUT=0.40             # USD per 1M output tokens   (both required)
#LIVE_MEMORY_PRICE_CACHE_READ_MULT=0.10    # cache-read rate as a fraction of input
#LIVE_MEMORY_PRICE_CACHE_WRITE_MULT=1.25   # cache-write rate as a fraction of input

# ── Logging ──
# By default logs go to stderr → journald (journalctl -u live-memory). Set
# LIVE_MEMORY_LOG_FILE to ALSO write a durable, rotating plain-text file
# (useful if your journald is volatile / lost on reboot).
#LIVE_MEMORY_LOG_LEVEL=INFO
#   user service:    %h/.local/state/live-memory/live-memory.log  (set the absolute path)
#   system service:  /var/log/live-memory/live-memory.log
#LIVE_MEMORY_LOG_FILE=/var/log/live-memory/live-memory.log
#LIVE_MEMORY_LOG_MAX_BYTES=10485760
#LIVE_MEMORY_LOG_BACKUPS=5
