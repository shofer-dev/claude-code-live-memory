#!/usr/bin/env bash
# Pre-push gate for the claude-code-live-memory repo: run the full test suite and
# BLOCK the push on any failure. Layout-agnostic — works in a direct clone or as a
# git submodule (it `cd`s to this repo's own top-level, never the parent's).
# Activate once with ./git-hooks/install.sh.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"
echo "[pre-push] Live Memory test gate → ./run-tests.sh"
exec ./run-tests.sh
