{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/notify.py\" edited"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "**/*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/notify.py\" changed"
          }
        ]
      }
    ]
  }
}
